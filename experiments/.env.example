# Copy to experiments/.env and fill in. Anything already in your shell env wins.

# --- required ---
PROJECT_ID=my-gcp-project
GCS_BUCKET=gs://my-bucket           # no trailing slash; the harness appends prefixes

# --- recommended (defaults shown) ---
LOCATION=global
BASE_AGENT=antigravity-preview-05-2026
PREFIX_A=workspaces/userA           # put a hello.txt under each prefix first:
PREFIX_B=workspaces/userB           #   echo hi | gcloud storage cp - gs://my-bucket/workspaces/userA/hello.txt

# --- optional ---
SKILL_RESOURCE_NAME=                # projects/.../locations/.../skills/<id> to test a skill_registry mount
TIMEOUT_MS=180000                   # per-interaction timeout
KEEP=0                              # set 1 to keep probe agents (skip cleanup)

# --- experiment 05 only (MCP reachability) ---
GATEWAY_URL=                        # https://my-gateway.run.app  (deployed control plane)
MCP_TOKEN=                          # a session/proxy bearer token the gateway will accept
